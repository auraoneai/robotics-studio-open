{
  "name": "@auraone/proofline-oss",
  "version": "0.1.0",
  "description": "Accessible evidence UI primitives and OSS-safe design tokens for AuraOne Open products.",
  "keywords": [
    "auraone",
    "proofline",
    "design-system",
    "react",
    "accessibility",
    "evidence",
    "audit",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auraoneai/open-studio-platform.git",
    "directory": "packages/proofline-oss"
  },
  "homepage": "https://github.com/auraoneai/open-studio-platform/tree/main/packages/proofline-oss#readme",
  "bugs": {
    "url": "https://github.com/auraoneai/open-studio-platform/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./src/styles.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && cp src/styles.css src/tokens.css dist/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment jsdom",
    "verify:public-assets": "node scripts/verify-public-assets.mjs"
  },
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1"
  },
  "dependencies": {
    "lucide-react": "0.554.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20.19.5"
  },
  "packageManager": "pnpm@10.18.0"
}
