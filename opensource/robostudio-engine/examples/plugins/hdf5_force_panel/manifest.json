{
  "schema": "https://schemas.auraone.ai/robotics-studio/plugin-manifest/v1.json",
  "plugin_id": "ai.auraone.robostudio.plugins.hdf5_force_panel",
  "name": "HDF5 Force Panel Example",
  "version": "0.1.0",
  "api": "robostudio.plugin.v1",
  "description": "Example third-party adapter and read-only panel plugin for force/torque HDF5 review.",
  "author": "AuraOne",
  "capabilities": ["local-only", "read-only-panel"],
  "contributions": [
    {
      "kind": "adapter",
      "id": "hdf5-force-profile",
      "title": "HDF5 force/torque profile",
      "entrypoint": "adapter.py",
      "formats": ["hdf5"],
      "permissions": ["read:dataset"]
    },
    {
      "kind": "panel",
      "id": "force-drift-panel",
      "title": "Force drift panel",
      "entrypoint": "panel.tsx",
      "slot": "episode-sidebar",
      "permissions": ["read:episode", "read:sensor-summary"]
    }
  ]
}
