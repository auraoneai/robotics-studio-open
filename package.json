{
  "name": "robotics-studio-open",
  "version": "0.1.0",
  "private": false,
  "description": "Robotics Studio Open local-first desktop review IDE.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "pnpm run platform:build",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "pretypecheck": "pnpm run platform:build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm run platform:build",
    "test": "tsx tests/studio-smoke.test.ts && tsx tests/platform-inheritance.test.ts && tsx tests/accessibility-smoke.test.ts",
    "smoke": "pnpm run typecheck && pnpm run test && pnpm run build",
    "tauri": "tauri",
    "desktop:check": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "platform:build": "pnpm --dir packages/platform-contracts build && pnpm --dir packages/aura-ide-kit build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@auraone/aura-ide-kit": "file:packages/aura-ide-kit",
    "@auraone/platform-contracts": "file:packages/platform-contracts",
    "@tauri-apps/api": "^2.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "lucide-react": "^0.554.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.56.0",
    "@tauri-apps/cli": "2.11.1",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.18.0"
  }
}
