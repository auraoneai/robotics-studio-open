{
  "name": "robotics-studio-open-repo",
  "version": "0.1.0",
  "private": true,
  "description": "Source workspace for Robotics Studio Open.",
  "type": "module",
  "scripts": {
    "build": "pnpm --dir opensource/robotics-studio build",
    "typecheck": "pnpm --dir opensource/robotics-studio typecheck",
    "test": "pnpm --dir opensource/robotics-studio test",
    "python:test": "PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 PYTHONPATH=opensource/robostudio-engine/src:opensource/robotics-reviewkit/src:opensource/lerobot-quality-gates/src:opensource/robot-recovery-bench/src:opensource/vla-robustness-kit/src:opensource/embodiment-card/src:opensource/failure-gallery/src python -m pytest -q opensource/robostudio-engine/tests",
    "python:build": "python -m build opensource/robostudio-engine"
  },
  "packageManager": "pnpm@10.18.0"
}
